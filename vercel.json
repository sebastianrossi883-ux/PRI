{
  "version": 2,
  "builds": [
    { "src": "web/**", "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/",
      "headers": { "cache-control": "public, max-age=0, must-revalidate" },
      "dest": "/web/index.html"
    },
    {
      "src": "/(.*)",
      "headers": { "cache-control": "public, max-age=0, must-revalidate" },
      "dest": "/web/$1"
    }
  ]
}
